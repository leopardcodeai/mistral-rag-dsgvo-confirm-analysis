{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3ReadOnlyAccess",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
        "Resource": [
        "arn:aws:s3:::rsi-test-data",
        "arn:aws:s3:::rsi-test-data/*"
      ]
    },
    {
      "Sid": "BedrockMistralAccess",
      "Effect": "Allow",
      "Action": [
        "bedrock:InvokeModel",
        "bedrock:InvokeModelWithResponseStream"
      ],
      "Resource": [
        "arn:aws:bedrock:eu-central-1::inference-profile/eu.mistral.pixtral-large-2502-v1:0",
        "arn:aws:bedrock:eu-central-1::foundation-model/mistral.pixtral-large-2502-v1:0"
      ]
    }
  ]
}